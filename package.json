{
  "name": "flowcraft",
  "version": "0.2.1",
  "description": "Multi-agent orchestration plugin for OpenCode — delegate tasks to specialist sub-agents, load Skills, manage MCP servers",
  "type": "module",
  "main": "dist/bundle.js",
  "exports": {
    ".": {
      "import": "./dist/bundle.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "dev": "node scripts/dev.mjs --watch",
    "deploy": "node scripts/dev.mjs"
  },
  "keywords": [
    "opencode",
    "plugin",
    "agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/J1I1E/flowcraft.git"
  },
  "homepage": "https://github.com/J1I1E/flowcraft#readme",
  "bugs": {
    "url": "https://github.com/J1I1E/flowcraft/issues"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.0",
    "@opencode-ai/sdk": "^1.4.0",
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
